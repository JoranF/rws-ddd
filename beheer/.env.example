# Beheer service - kopieer naar .env
SERVICE_PORT=8004
DATABASE_URL=postgresql+psycopg://rws:rws@postgres:5432/beheer_db
RABBITMQ_URL=amqp://rws:rws@rabbitmq:5672
ENABLE_RABBITMQ_CONSUMERS=true

# JWT-authenticatie (Keycloak/OIDC). AUTH_ENABLED=false => auth volledig uit (default).
AUTH_ENABLED=false
OIDC_ISSUER=https://keycloak.joranit.com/realms/rws
OIDC_JWKS_URI=https://keycloak.joranit.com/realms/rws/protocol/openid-connect/certs
OIDC_REQUIRED_ROLE=beheer
