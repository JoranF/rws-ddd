# Contract service — kopieer naar .env
SERVICE_PORT=8001
DATABASE_URL=postgres://rws:rws@postgres:5432/contract_db
RABBITMQ_URL=amqp://rws:rws@rabbitmq:5672
# Kunstwerk-validatie bij gunnen:
#   soepel  = Fase 1 (onbekend kunstwerk -> waarschuwing, gunning gaat door)
#   streng  = Fase 2 (onbekend/buitengebruikgesteld kunstwerk -> gunning geweigerd)
# Streng vereist dat het read-model gevuld is door beheer.kunstwerk.*-events.
KUNSTWERK_VALIDATIE=streng
