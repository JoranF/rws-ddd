# Contract service — kopieer naar .env
SERVICE_PORT=8001
DATABASE_URL=postgres://rws:rws@postgres:5432/contract_db
RABBITMQ_URL=amqp://rws:rws@rabbitmq:5672
# Kunstwerk-validatie bij gunnen:
#   soepel  = Fase 1 (onbekend kunstwerk -> waarschuwing, gunning gaat door)
#   streng  = Fase 2 (onbekend/buitengebruikgesteld kunstwerk -> gunning geweigerd)
# Streng vereist dat het read-model gevuld is door beheer.kunstwerk.*-events.
KUNSTWERK_VALIDATIE=streng

# --- JWT-authenticatie (OIDC / Keycloak) ---
# Feature-flag: false (default) = auth uit (bestaand gedrag). true = afdwingen.
AUTH_ENABLED=false
# Verwachte token-uitgever (iss). Read (GET) mag elke ingelogde gebruiker;
# schrijven (POST/PUT/PATCH/DELETE) vereist de rol uit OIDC_REQUIRED_ROLE
# in de realm_access.roles-claim.
OIDC_ISSUER=https://keycloak.joranit.com/realms/rws
OIDC_JWKS_URI=https://keycloak.joranit.com/realms/rws/protocol/openid-connect/certs
OIDC_REQUIRED_ROLE=contract
