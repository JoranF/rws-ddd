# Onderhoud service — kopieer naar .env
SERVICE_PORT=8003
DATABASE_URL=postgres://rws:rws@postgres:5432/onderhoud_db
RABBITMQ_URL=amqp://rws:rws@rabbitmq:5672
VALIDATIE=soepel

# JWT-authenticatie (OIDC / Keycloak). AUTH_ENABLED=false = auth volledig uit (huidig gedrag).
AUTH_ENABLED=false
OIDC_ISSUER=https://keycloak.joranit.com/realms/rws
OIDC_JWKS_URI=https://keycloak.joranit.com/realms/rws/protocol/openid-connect/certs
OIDC_REQUIRED_ROLE=onderhoud
